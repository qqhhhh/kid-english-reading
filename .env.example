# Local development defaults. This file intentionally contains no third-party keys.
HOST=127.0.0.1
PORT=4175
# Local development does not trust forwarded client addresses. When a
# production reverse proxy runs on the same machine, use HTTP_TRUST_PROXY=loopback.
HTTP_TRUST_PROXY=0
# Production browser origins must be listed explicitly, comma-separated.
CORS_ALLOWED_ORIGINS=
SPEECH_PROVIDER=mock
TENCENT_STREAMING_ENABLED=0
SPEECH_ENHANCEMENT_PROVIDER=disabled
SPEECH_ENHANCEMENT_AB=0
KID_READING_SAVE_AUDIO=0
KID_READING_SEED_DEMO=0
LOCAL_COURSE_STUDIO_ENABLED=1
PDF_IMPORT_VERIFIERS=tesseract
PDF_IMPORT_CLOUD_MODE=review
AI_PROVIDER=disabled
