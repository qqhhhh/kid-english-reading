{
  "name": "kid-english-reading",
  "version": "0.7.1",
  "private": true,
  "description": "Self-hosted English reading and pronunciation practice for families.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qqhhhh/kid-english-reading.git"
  },
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "node scripts/startDev.mjs",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:api": "node server/dev.js",
    "build": "tsc && vite build",
    "cap:doctor": "cap doctor",
    "cap:sync": "cap sync",
    "key:create:dev": "node scripts/createRegistrationKey.mjs --dev",
    "ocr:hunyuan:start": "node scripts/hunyuanOcrControl.mjs start",
    "ocr:hunyuan:stop": "node scripts/hunyuanOcrControl.mjs stop",
    "test": "node --test",
    "test:visual": "node scripts/runVisualTests.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node server/index.js",
    "server": "node server/index.js"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@ricky0123/vad-web": "^0.0.30",
    "@tesseract.js-data/eng": "^1.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.9.3",
    "lucide-react": "^0.525.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "multer": "^2.0.1",
    "nanoid": "^5.1.5",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sherpa-onnx-node": "^1.13.3",
    "tesseract.js": "^7.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-static-copy": "^3.1.2"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
