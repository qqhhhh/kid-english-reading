{
  "name": "kid-english-reading-mvp",
  "version": "0.7.3",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "dev": "tsx scripts/startDev.ts",
    "dev:web": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:api": "node --import tsx server/dev.ts",
    "typecheck": "npm run typecheck:client && npm run typecheck:server && npm run typecheck:tools",
    "typecheck:client": "tsc --noEmit",
    "typecheck:server": "tsc --project tsconfig.server.json --noEmit",
    "typecheck:tools": "tsc --project tsconfig.tools.json && tsc --project tsconfig.browser-tests.json",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc --noEmit && vite build",
    "build:server": "tsc --project tsconfig.server.json",
    "smoke:server-build": "npm run build:server && tsx scripts/smokeServerBuild.ts",
    "cap:doctor": "cap doctor",
    "cap:sync": "cap sync",
    "key:create:dev": "tsx scripts/createRegistrationKey.ts --dev",
    "ocr:hunyuan:start": "tsx scripts/hunyuanOcrControl.ts start",
    "ocr:hunyuan:stop": "tsx scripts/hunyuanOcrControl.ts stop",
    "ocr:paddle:start": "tsx scripts/paddleOcrControl.ts start",
    "ocr:paddle:stop": "tsx scripts/paddleOcrControl.ts stop",
    "test": "tsx --test",
    "test:visual": "tsx scripts/runVisualTests.ts",
    "preview": "vite preview --host 127.0.0.1",
    "start": "node .server-build/server/index.js",
    "server": "node .server-build/server/index.js"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.1",
    "@ricky0123/vad-web": "^0.0.30",
    "@tesseract.js-data/eng": "^1.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.9.3",
    "lucide-react": "^0.525.0",
    "microsoft-cognitiveservices-speech-sdk": "^1.50.0",
    "multer": "^2.0.1",
    "nanoid": "^5.1.5",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sherpa-onnx-node": "^1.13.3",
    "tesseract.js": "^7.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.10",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-static-copy": "^3.1.2"
  }
}
