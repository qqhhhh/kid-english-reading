# Bind Express only to loopback and publish it through an HTTPS reverse proxy.
HOST=127.0.0.1
PORT=4175

# Trust forwarded client addresses only from the local reverse proxy. Never use
# true or 1 because that trusts arbitrary forwarding headers.
HTTP_TRUST_PROXY=loopback
CORS_ALLOWED_ORIGINS=https://reading.example.com

# Replace these example hosts with the installation's own HTTPS domain.
AUTH_COOKIE_DOMAIN=.example.com
PRIMARY_AUTH_HOSTS=example.com,reading.example.com
PRIMARY_AUTH_ORIGIN=https://reading.example.com

# Safe source-only defaults. Add provider credentials only to the untracked .env.
SPEECH_PROVIDER=mock
TENCENT_STREAMING_ENABLED=0
SPEECH_ENHANCEMENT_PROVIDER=disabled
SPEECH_ENHANCEMENT_AB=0
KID_READING_SAVE_AUDIO=0
KID_READING_SEED_DEMO=0
LOCAL_COURSE_STUDIO_ENABLED=0
PDF_IMPORT_VERIFIERS=tesseract
PDF_IMPORT_CLOUD_MODE=review
AI_PROVIDER=disabled
